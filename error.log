(
    [queryString] => SELECT p.id as post_id, p.pic, p.title, p.comment, p.create_at, p.update_at, u.id as user_id, u.username,
        u.pic as user_icon, s.name as situation_name, l.name as lens_name, f.name as film_name
        FROM posts as p
        LEFT JOIN
        users as u
        ON
